{
  "name": "yukon-server",
  "version": "1.11.0-beta",
  "description": "A server for https://github.com/wizguin/yukon",
  "scripts": {
    "dev": "nodemon ./src/World.ts Login Blizzard",
    "build": "rimraf dist && tsc && tsc-alias",
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "list": "pm2 list",
    "logs": "pm2 logs",
    "monit": "pm2 monit",
    "secret-gen": "node ./utils/secret-gen.js",
    "test": "node -r ts-node/register -r tsconfig-paths/register --test tests/**/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wizguin/yukon-server.git"
  },
  "author": "wizguin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wizguin/yukon-server/issues"
  },
  "homepage": "https://github.com/wizguin/yukon-server#readme",
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@prisma/adapter-mariadb": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "dotenv": "^17.2.3",
    "eslint": "^9.38.0",
    "nodemon": "^3.1.10",
    "prisma": "^7.1.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "ts-runtime-checks": "^0.6.3",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "fastest-validator": "^1.19.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.3",
    "pm2": "^6.0.8",
    "rate-limiter-flexible": "^7.2.0",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.9",
    "utf-8-validate": "^6.0.5"
  }
}
