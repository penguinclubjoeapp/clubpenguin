# ============================================================================
# Club Penguin Discord Bridge — Environment Configuration
# ============================================================================
#
# SETUP:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Fill in values marked **MUST CHANGE** or **MUST SET**
#   3. Values with defaults can be left as-is for local development
#
# .env is gitignored and will not be committed.
#
# See README.md for the full quickstart guide.
#
# Legend:
#   MUST CHANGE — default is insecure or placeholder; you must provide your own
#   MUST SET    — no default; the service will not start without it
#   Has default — works out of the box for local/Docker development
# ============================================================================


# ----------------------------------------------------------------------------
# PostgreSQL Database
# ----------------------------------------------------------------------------
# WARNING: Changing credentials after initial setup requires manual DB
# migration (update the postgres user/password inside the running container
# or recreate the volume).

POSTGRES_USER=penguin                  # Has default
POSTGRES_PASSWORD=changeme             # **MUST CHANGE** — pick a strong password
POSTGRES_DB=penguin                    # Has default
POSTGRES_HOST=postgres                 # Has default (Docker Compose service name)
POSTGRES_PORT=5432                     # Has default


# ----------------------------------------------------------------------------
# Discord Bot Configuration
# ----------------------------------------------------------------------------
# How to obtain your bot token:
#   1. Go to https://discord.com/developers/applications → New Application
#   2. Bot tab → Reset Token → copy the token
#   3. Enable "Server Members Intent" and "Message Content Intent"
#   4. OAuth2 → URL Generator → select "bot" scope
#      Required permissions: Move Members, Connect, View Channels
#   5. Use the generated URL to invite the bot to your server
#   6. Ensure the bot's role is ABOVE users it needs to move in the role
#      hierarchy (Server Settings → Roles → drag bot role up)
#
# How to get your Guild ID:
#   1. In Discord, go to User Settings → Advanced → enable Developer Mode
#   2. Right-click your server name → Copy Server ID

DISCORD_BOT_TOKEN=                     # **MUST SET** — paste bot token here
DISCORD_GUILD_ID=                      # **MUST SET** — your Discord server ID
DISCORD_BOT_PREFIX=!                   # Has default


# ----------------------------------------------------------------------------
# Houdini Game Server
# ----------------------------------------------------------------------------

GAME_LOGIN_PORT=6112                   # Has default
GAME_WORLD_PORT=6113                   # Has default
GAME_ADDRESS=127.0.0.1                 # Has default — set to public IP/domain for remote play


# ----------------------------------------------------------------------------
# Dash Web Services
# ----------------------------------------------------------------------------

DASH_PORT=3000                         # Has default
WEB_HOSTNAME=localhost                 # Has default — set to domain/IP for remote access


# ----------------------------------------------------------------------------
# Media Server (nginx)
# ----------------------------------------------------------------------------
# The media directory must be populated with Club Penguin SWF assets
# separately. See README.md for download/setup instructions.

MEDIA_PORT=80                          # Has default — change if port 80 is already in use


# ----------------------------------------------------------------------------
# Discord Bot Internal API
# ----------------------------------------------------------------------------
# Internal endpoint used for Houdini → bot communication (e.g. notifying the
# bot when a player changes rooms). This is NOT exposed outside Docker.

BOT_API_PORT=3001                      # Has default
BOT_API_HOST=discord-bot               # Has default (Docker Compose service name)


# ----------------------------------------------------------------------------
# Room-to-Channel Mappings (NOT environment variables)
# ----------------------------------------------------------------------------
# Room-to-voice-channel mappings are stored in the `room_channel_mappings`
# PostgreSQL table, NOT as env vars. This scales to 65+ rooms (base game,
# igloos, modded rooms) without env-var bloat, and can be updated at runtime.
#
# Managed via bot commands, e.g.:
#   !mapchannel 100 #town
#   !mapchannel 110 #coffee-shop
#   !mapchannel 800 #igloo-party
#
# Format in DB:  room_id (integer) → channel_id (Discord snowflake)
#   Example: room_id=100, channel_id=123456789012345678 (Town)
#   Example: room_id=110, channel_id=234567890123456789 (Coffee Shop)
#   Example: room_id=800, channel_id=345678901234567890 (Igloo)
#
# Rooms without a mapping are silently ignored (no voice channel change).


# ----------------------------------------------------------------------------
# Link Code Expiry
# ----------------------------------------------------------------------------

LINK_CODE_EXPIRY_SECONDS=300           # Has default (5 minutes)


# ----------------------------------------------------------------------------
# Redis (required by Houdini for player state)
# ----------------------------------------------------------------------------

REDIS_HOST=redis                       # Has default (Docker Compose service name)
REDIS_PORT=6379                        # Has default


# ----------------------------------------------------------------------------
# Optional — Dash Extras (uncomment to enable)
# ----------------------------------------------------------------------------
# Only needed if enabling public registration with captcha and/or email
# verification. Leave commented out for private/local servers.

# WEB_RECAPTCHA_SITE=
# WEB_RECAPTCHA_SECRET=
# WEB_SENDGRID_KEY=
